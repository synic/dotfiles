#!/usr/bin/env python
"""create a csv of ec2 instance information"""

import json
import subprocess
import sys

if __name__ == '__main__':
    cmd = 'aws ec2 describe-instances'
    if len(sys.argv) > 1:
        cmd = '{} --filter Name=tag:Name,Values=*{}*'.format(cmd, sys.argv[1])

    output = subprocess.check_output(cmd.split(' '))

    data = json.loads(output)

    for d in data['Reservations']:
        name =''
        for tag_bag in d['Instances'][0]['Tags']:
            if tag_bag['Key'] == 'Name':
                name = tag_bag['Value']
                break

        try:
            private_ip = d['Instances'][0]['PrivateIpAddress']
        except KeyError:
            private_ip = 'n/a'

        print '{}\t{}'.format(name, private_ip)
