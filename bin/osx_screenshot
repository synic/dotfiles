#!/usr/bin/env python

import hashlib
import httplib
import os
import os.path
import sys
import time
import traceback


fn = "/tmp/%s.png" % hashlib.md5(str(time.time())).hexdigest()[:7]
sn = os.path.basename(fn)
os.system("screencapture -s {}".format(fn))
cmd = (
    "scp -i ~/.ssh/id_rsa_sbss %s "
    "shittybum.com:/home/synic/vt/screenshots/" % fn)
os.system(cmd)

url = "http://synic.world/s/%s" % sn


class NotFound(Exception):
    pass


def display_notification(title, message):
    os.system("""
/usr/bin/osascript -e "display notification \\\"{}\\\" with title
\\\"{}\\\""
    """.format(message, title).replace('\n', ' '))


try:
    conn = httplib.HTTPConnection('synicworld.com')
    conn.request('HEAD', '/media/screenshots/%s' % sn)
    response = conn.getresponse()
    if response.status != 200:
        raise NotFound()
except (StandardError, NotFound):
    traceback.print_exc()
    display_notification("Error uploading", "Screenshot was not uploaded.")
    sys.exit(1)

display_notification("Screenshot uploaded", url)
os.system("echo '{}' | pbcopy".format(url))
